{
  "manifest_version": 3,
  "name": "Claude Usage Monitor",
  "version": "1.0",
  "key": "",
  "description": "Fetches Claude usage stats for statusline",
  "background": { "service_worker": "background.js" },
  "permissions": ["nativeMessaging", "alarms", "storage"],
  "host_permissions": ["https://claude.ai/api/*"],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
